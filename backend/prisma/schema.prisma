generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  role            Role           @default(STAFF)
  clientId        String?        @unique
  client          Client?        @relation("BusinessAccount", fields: [clientId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  orders          Order[]
  assignedClients Client[]       @relation("StaffClients")
  deliveries      Delivery[]
  shopProducts    ShopProduct[]
  shopSales       ShopSale[]

  @@map("users")
}

model Product {
  id              String               @id @default(uuid())
  name            String
  description     String?
  price           Decimal              @db.Decimal(10, 2)
  stock           Int                  @default(0)
  category        String
  imageUrl        String?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  orderItems      OrderItem[]
  deliveryItems   DeliveryItem[]
  clientPrices    ClientProductPrice[]
  dailyStockItems DailyStockItem[]

  @@map("products")
}

model Order {
  id         String      @id @default(uuid())
  orderNo    String      @unique @default(cuid())
  status     OrderStatus @default(PENDING)
  isPaid     Boolean     @default(false)
  totalPrice Decimal     @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  createdBy  User        @relation(fields: [userId], references: [id])
  userId     String
  items      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id])
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String

  @@map("order_items")
}

model Client {
  id          String               @id @default(uuid())
  name        String
  address     String?
  phone       String?
  notes       String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignedTo  User                 @relation("StaffClients", fields: [staffId], references: [id])
  staffId     String
  businessUser User?               @relation("BusinessAccount")
  deliveries  Delivery[]
  prices      ClientProductPrice[]

  @@map("clients")
}

model ClientProductPrice {
  id        String  @id @default(uuid())
  price     Decimal @db.Decimal(10, 2)
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@unique([clientId, productId])
  @@map("client_product_prices")
}

model Delivery {
  id           String         @id @default(uuid())
  status       DeliveryStatus @default(PENDING)
  isPaid       Boolean        @default(false)
  notes        String?
  deliveryDate DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  client       Client         @relation(fields: [clientId], references: [id])
  clientId     String
  createdBy    User           @relation(fields: [staffId], references: [id])
  staffId      String
  items        DeliveryItem[]

  @@map("deliveries")
}

model DeliveryItem {
  id         String   @id @default(uuid())
  quantity   Int
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  deliveryId String

  @@map("delivery_items")
}

model DailyStock {
  id        String           @id @default(uuid())
  date      DateTime         @db.Date
  status    DailyStockStatus @default(OPEN)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  items     DailyStockItem[]

  @@unique([date])
  @@map("daily_stocks")
}

model DailyStockItem {
  id           String     @id @default(uuid())
  quantity     Int
  dailyStock   DailyStock @relation(fields: [dailyStockId], references: [id], onDelete: Cascade)
  dailyStockId String
  product      Product    @relation(fields: [productId], references: [id])
  productId    String

  @@unique([dailyStockId, productId])
  @@map("daily_stock_items")
}

model ShopProduct {
  id        String         @id @default(uuid())
  name      String
  price     Decimal        @db.Decimal(10, 2)
  isActive  Boolean        @default(true)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  saleItems ShopSaleItem[]

  @@map("shop_products")
}

model ShopSale {
  id       String         @id @default(uuid())
  saleDate DateTime       @default(now())
  notes    String?
  userId   String
  user     User           @relation(fields: [userId], references: [id])
  items    ShopSaleItem[]

  @@map("shop_sales")
}

model ShopSaleItem {
  id            String      @id @default(uuid())
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  shopSaleId    String
  shopSale      ShopSale    @relation(fields: [shopSaleId], references: [id], onDelete: Cascade)
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  @@map("shop_sale_items")
}

enum DailyStockStatus {
  OPEN
  CLOSED
}

enum Role {
  ADMIN
  STAFF
  BUSINESS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  BAKING
  READY
  DELIVERED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  COMPLETED
  CANCELLED
}
